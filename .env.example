# Firebase project ID.
# Find it at: https://console.firebase.google.com/project/_/settings/general
# (Look for "Project ID" — it usually looks like "my-app-12345".)
PROJECT_ID=your-firebase-project-id

# Absolute or relative path to the service-account JSON key file you downloaded
# from Firebase Console > Project settings > Service accounts > Generate new private key.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
